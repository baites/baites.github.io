
{% assign class = "remark" %}
{% assign logo = "fas fa-exclamation-circle" %}
<div markdown="{{ include.markdown | default: 'span' }}" class="{{ class }}" role="statement"> 
{% if include.name %}
<i class="{{ logo }}"/> <b>{{ class | capitalize }} <i>({{ include.name }})</i>:</b>
{% else %}
<i class="{{ logo }}"/> <b>{{ class | capitalize }}:</b>
{% endif %}